<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
  </head>
  <body>
    <% messages.forEach((message) => { %>
      <section>
        <p><%= message.text%></p>
        <p><%= message.user%></p>
        <p><%= message.added%></p>
      </section>
   <% }) %>
  </body>
</html>
